# pyenv
#   For a library or app, you might want to share your .python-version if you use pyenv
#   but it's often ignored to avoid locking users to a specific version.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of a library, pipfile should be ignored.
#   Pipfile.lock

# poetry
#   poetry.lock is usually committed, but in some setups it's ignored.
#   .poetry/poetry.lock

# pdm
#   pdm.lock is usually committed, but in some setups it's ignored.
#   .pdm.toml
#   .pdm-plugins/

# venv
#   Virtual environments are user-specific and should not be committed.
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# VS Code settings
.vscode/

# JetBrains / PyCharm settings
.idea/

# Local OS files
